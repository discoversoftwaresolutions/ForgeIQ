# General
NODE_ENV=development
LOG_LEVEL=info

# DebugIQ Core API
# PORT=10000 (Render injects this, but useful for local dev)

# Redis (for Event Bus & Shared Memory)
REDIS_URL=redis://localhost:6379

# ForgeIQ UI
# For Vite:
VITE_APP_TITLE=ForgeIQ Platform
VITE_API_BASE_URL=http://localhost:10000/api # Update this once debugiq-core is deployed on Render
# For Create React App (if you switch):
# REACT_APP_APP_TITLE=ForgeIQ Platform
# REACT_APP_API_BASE_URL=http://localhost:10000/api

# Agent Specific Variables (Examples - Add more as needed)
# PLAN_AGENT_MAX_RETRIES=3
# CODE_NAV_AGENT_EMBEDDING_MODEL=text-embedding-ada-002
# OPENAI_API_KEY=your_openai_api_key_here (if CodeNav or others use OpenAI)

# External Service API Keys
# GITHUB_TOKEN=your_github_token_for_ci_cd_agent_or_plugins
