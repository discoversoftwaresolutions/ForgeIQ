# General
NODE_ENV=development

# DebugIQ Core API
# PORT=10000 # Usually injected by Render

# Redis (for Event Bus & Shared Memory)
REDIS_URL=redis://localhost:6379 # Example for local dev

# ForgeIQ UI
# For Vite: VITE_API_BASE_URL=http://localhost:10000/api
# For Create React App: REACT_APP_API_BASE_URL=http://localhost:10000/api

# Agent Specific Variables (Examples)
# PLAN_AGENT_MAX_RETRIES=3
# CODE_NAV_AGENT_EMBEDDING_MODEL=text-embedding-ada-002

# External Service API Keys (Add as needed)
# GITHUB_TOKEN=
# OPENAI_API_KEY=

# CI/CD Specific (if any are passed to the application)
