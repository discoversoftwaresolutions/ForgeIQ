{
  "version": 1,
  "projects": {
    "forgeiq-ui": {
      "path": "apps/forgeiq-ui",
      "type": "app",
      "description": "ForgeIQ front-end dashboard"
    },
    "debugiq-core": {
      "path": "apps/debugiq-core",
      "type": "app",
      "description": "DebugIQ back-end APIs"
    },
    "agent-cli": {
      "path": "apps/agent-cli",
      "type": "app",
      "description": "CLI for agentic build system"
    },
    
    "CodeNavAgent": { "path": "agents/CodeNavAgent", "type": "agent", "description": "Proprietary Cursor-like model (semantic embedding + search)" },
    "BuildSurfAgent": { "path": "agents/BuildSurfAgent", "type": "agent", "description": "Proprietary Windsurf-style intent-to-DAG pipeline planner" },
    "PlanAgent": { "path": "agents/PlanAgent", "type": "agent", "description": "Task planning, DAG generation, target resolution" },
    "DependencyAgent": { "path": "agents/DependencyAgent", "type": "agent", "description": "Change detection and dependency diffing" },
    "WorkflowAgent": { "path": "agents/WorkflowAgent", "type": "agent", "description": "DAG validation, cycle detection, workflow pre-flight clearance" },
    "SyntaxAgent": { "path": "agents/SyntaxAgent", "type": "agent", "description": "Ghost syntax error scanning and static analysis" },
    "TestAgent": { "path": "agents/TestAgent", "type": "agent", "description": "Unit/integration test runner (uses DebugIQ)" },
    "PatchAgent": { "path": "agents/PatchAgent", "type": "agent", "description": "AutoPatch generation from DebugIQ + CodeNav context" },
    "CacheAgent": { "path": "agents/CacheAgent", "type": "agent", "description": "Smart caching and build artifact reuse" },
    "CI_CD_Agent": { "path": "agents/CI_CD_Agent", "type": "agent", "description": "CI/CD orchestration (GitHub Actions, ECS, Terraform)" },
    "ReportingAgent": { "path": "agents/ReportingAgent", "type": "agent", "description": "Logs metrics to dashboards, ELK, or S3" },
    "SecurityAgent": { "path": "agents/SecurityAgent", "type": "agent", "description": "Code scanning, IaC security checks" },
    "GovernanceAgent": { "path": "agents/GovernanceAgent", "type": "agent", "description": "Logs build trails, agent signatures, provenance" },
    
    "core-build-graph": { "path": "core/build-graph", "type": "lib", "description": "Project DAG management, incremental build graph" },
    "core-task-runner": { "path": "core/task-runner", "type": "lib", "description": "Low-level task execution logic" },
    "core-embeddings": { "path": "core/embeddings", "type": "lib", "description": "CodeNav embedding model + vector DB interface" },
    
    "interfaces-types": { "path": "interfaces/types", "type": "lib", "description": "Shared type definitions" },
    "interfaces-sdk": { "path": "interfaces/sdk", "type": "lib", "description": "Shared SDKs" },
    
    "plugin-github-actions": { "path": "plugins/github-actions", "type": "plugin", "description": "GitHub Actions generators and agents" },
    "plugin-terraform-modules": { "path": "plugins/terraform-modules", "type": "plugin", "description": "ECS, Lambda, S3 IaC" },
    "plugin-amplify-deploy": { "path": "plugins/amplify-deploy", "type": "plugin", "description": "Amplify-specific deployment logic" },
    "plugin-ci-cd-hooks": { "path": "plugins/ci-cd-hooks", "type": "plugin", "description": "Pre/post-deploy agentic hooks" },
    
    "shared-utils": { "path": "shared/utils", "type": "lib", "description": "Generic utilities" }
  }
}
