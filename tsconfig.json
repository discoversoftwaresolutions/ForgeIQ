{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true, // This base config doesn't emit; individual projects will.
    "jsx": "react-jsx", // For ForgeIQ UI
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".", // Allows for path aliases if configured
    "paths": { // Example path aliases (sub-projects will need to reference these in their tsconfig)
      "@shared/*": ["shared/*"],
      "@interfaces/*": ["interfaces/*"],
      "@core/*": ["core/*"]
    }
  },
  "exclude": ["node_modules", "**/dist", "**/build", "**/*.bak"]
}
